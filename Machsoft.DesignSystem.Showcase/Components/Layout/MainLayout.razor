@inherits LayoutComponentBase
@using MudBlazor

<MxDesignSystemProvider IsDarkMode="@IsDarkMode" @key="IsDarkMode">
    <MxNavigationShell Class="@ShellClass">
        <AppBarContent>
            <MxAppBar LogoText="SCENARIO SIMULATION AND DESIGN" Color="Color.Primary" Elevation="1" Class="showcase-appbar"
                     LeadingContent="@AppBarLeading" ActionsContent="@AppBarActions" />
        </AppBarContent>

        <DrawerContent>
            <NavMenu ShowCloseButton="true" OnClose="CloseMenu" />
        </DrawerContent>

        <MainContent>
            <MxContainer MaxWidth="MaxWidth.False" Class="showcase-main-container">
                @Body
            </MxContainer>
        </MainContent>
    </MxNavigationShell>
</MxDesignSystemProvider>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool IsDarkMode;
    private bool IsMenuOpen = true;

    private string ShellClass => IsMenuOpen ? "showcase-shell showcase-shell--drawer-open" : "showcase-shell";

    private string ThemeLabel => IsDarkMode ? "Modo claro" : "Modo oscuro";
    private string ThemeIcon => IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    private RenderFragment AppBarLeading =>
        @<MxButton Variant="Variant.Text" Color="Color.Inherit" Class="showcase-appbar__menu-button" OnClick="ToggleMenu">
            <MxIcon Icon="@Icons.Material.Filled.Menu" />
        </MxButton>;

    private RenderFragment AppBarActions =>
        @<div class="showcase-appbar__actions-row">
            <MxLink Href="/components" Text="Project designer" Color="Color.Inherit" Class="showcase-appbar__project-link" />
            <MxButton Variant="Variant.Text" Color="Color.Inherit" OnClick="ToggleTheme" StartIcon="@ThemeIcon" Class="showcase-appbar__theme-button">
                @ThemeLabel
            </MxButton>
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" Size="Size.Medium" />
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Size="Size.Medium" />
            <MudIconButton Icon="@Icons.Material.Filled.Fullscreen" Color="Color.Inherit" Size="Size.Medium" />
        </div>;

    private void ToggleTheme(MouseEventArgs _)
    {
        IsDarkMode = !IsDarkMode;
        StateHasChanged();
    }

    private void ToggleMenu(MouseEventArgs _)
    {
        IsMenuOpen = !IsMenuOpen;
    }

    private void CloseMenu()
    {
        IsMenuOpen = false;
    }
}
