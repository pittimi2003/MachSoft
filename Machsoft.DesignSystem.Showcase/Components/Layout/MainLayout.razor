@inherits LayoutComponentBase
@using MudBlazor

<MxDesignSystemProvider IsDarkMode="@IsDarkMode">
    <MxNavigationShell Class="showcase-shell">
        <AppBarContent>
            <MxAppBar LogoText="MachSoft Design System" Color="Color.Primary" Elevation="1">
                <MxButton Variant="Variant.Text" Color="Color.Inherit" OnClick="ToggleTheme" StartIcon="@ThemeIcon">
                    @ThemeLabel
                </MxButton>
                <MxLink Href="/components" Text="Catálogo" Color="Color.Inherit" />
            </MxAppBar>
        </AppBarContent>

        <DrawerContent>
            <NavMenu />
        </DrawerContent>

        <MainContent>
            <MxContainer MaxWidth="MaxWidth.False" Class="showcase-main-container">
                @Body
            </MxContainer>
        </MainContent>
    </MxNavigationShell>
</MxDesignSystemProvider>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool IsDarkMode;

    private string ThemeLabel => IsDarkMode ? "Modo oscuro" : "Modo claro";

    private string ThemeIcon => IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode;

    private void ToggleTheme(MouseEventArgs _)
    {
        IsDarkMode = !IsDarkMode;
    }
}
