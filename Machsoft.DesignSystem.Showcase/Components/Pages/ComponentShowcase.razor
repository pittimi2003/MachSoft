@page "/components"
@page "/components/{ComponentKey}"
@inject Machsoft.DesignSystem.Showcase.Services.ComponentShowcaseRegistry Registry

<PageTitle>Component Showcase</PageTitle>

<div class="showcase-layout">
    <aside class="showcase-sidebar">
        <h3>Componentes Mx*</h3>
        @foreach (var item in Registry.Items)
        {
            <a class="showcase-link @(Selected?.Key == item.Key ? "active" : null)" href="@($"/components/{item.Key}")">@item.Name</a>
        }
    </aside>

    <section class="showcase-content">
        @if (Selected is null)
        {
            <h1>Design System Showcase</h1>
            <p>Selecciona un componente para ver ejemplo funcional, render actual y casos básicos certificados.</p>
        }
        else
        {
            <h1>@Selected.Name</h1>

            <div class="preview-host">
                <ErrorBoundary>
                    <ChildContent>
                        <DynamicComponent Type="Selected.Type" Parameters="Selected.Parameters" />
                    </ChildContent>
                    <ErrorContent>
                        <div class="alert alert-warning">Este componente requiere parámetros adicionales para mostrarse correctamente.</div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>

            <h4>Casos básicos validados</h4>
            <ul>
                @foreach (var check in Selected.CertificationChecks)
                {
                    <li>@check</li>
                }
            </ul>

            <h4>Código de ejemplo</h4>
            <pre><code>@Selected.SampleCode</code></pre>
        }
    </section>
</div>

@code {
    [Parameter] public string? ComponentKey { get; set; }

    private Machsoft.DesignSystem.Showcase.Services.ComponentShowcaseItem? Selected;

    protected override void OnParametersSet()
    {
        Selected = Registry.Find(ComponentKey);
    }
}
