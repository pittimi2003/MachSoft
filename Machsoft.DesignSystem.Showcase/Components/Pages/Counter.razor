@page "/counter"
@rendermode InteractiveServer
@using MudBlazor

<PageTitle>Counter</PageTitle>

<MxPaper Class="showcase-page" Outlined="true">
    <h1>Counter</h1>

    <p class="showcase-page__status" role="status">Current count: @currentCount</p>

    <MxButton Color="Color.Primary" Variant="Variant.Filled" OnClick="IncrementCount" StartIcon="@Icons.Material.Filled.Add">
        Incrementar
    </MxButton>
</MxPaper>

@code {
    private int currentCount;

    private void IncrementCount(MouseEventArgs _)
    {
        currentCount++;
    }
}
