@using MudBlazor

<MudSpeedDial Icon="@Icon"
              OpenIcon="@OpenIcon"
              Color="@Color"
              Direction="@Direction"
              Position="@Position"
              Variant="@Variant"
              Disabled="@Disabled"
              Class="@Class"
              Style="@Style">
    @if (Actions is not null)
    {
        @foreach (var action in Actions)
        {
            <MudSpeedDialItem Icon="@action.Icon"
                              Text="@action.Text"
                              Color="@action.Color"
                              OnClick="@(() => OnActionAsync(action))" />
        }
    }

    @ChildContent
</MudSpeedDial>

@code {
    public sealed record FabAction(string Text, string Icon, Color Color = Color.Primary);

    [Parameter] public IEnumerable<FabAction>? Actions { get; set; }
    [Parameter] public EventCallback<FabAction> ActionClicked { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Menu;
    [Parameter] public string OpenIcon { get; set; } = Icons.Material.Filled.Close;
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Direction { get; set; } = "Up";
    [Parameter] public Position Position { get; set; } = Position.Bottom;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private async Task OnActionAsync(FabAction action)
    {
        if (ActionClicked.HasDelegate)
            await ActionClicked.InvokeAsync(action);
    }
}
