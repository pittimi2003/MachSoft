@using MudBlazor

<MudCard Class="@Class" Style="@Style" Outlined="@Outlined" Elevation="@Elevation">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(SubTitle))
    {
        <MudCardHeader>
            <CardHeaderContent>
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <MudText Typo="Typo.h6">@Title</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(SubTitle))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@SubTitle</MudText>
                }
            </CardHeaderContent>
            @if (HeaderActions is not null)
            {
                <CardHeaderActions>
                    @HeaderActions
                </CardHeaderActions>
            }
        </MudCardHeader>
    }

    @if (ChildContent is not null)
    {
        <MudCardContent>
            @ChildContent
        </MudCardContent>
    }

    @if (Actions is not null)
    {
        <MudCardActions>
            @Actions
        </MudCardActions>
    }
</MudCard>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? SubTitle { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public bool Outlined { get; set; }
    [Parameter] public int Elevation { get; set; } = 1;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
}
