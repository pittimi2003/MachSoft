@using MudBlazor

<MudDateRangePicker DateRange="@DateRange"
                    DateRangeChanged="@DateRangeChanged"
                    Label="@Label"
                    Variant="@Variant"
                    Margin="@Margin"
                    Editable="@Editable"
                    Disabled="@Disabled"
                    PickerVariant="@PickerVariant"
                    Class="@Class"
                    Style="@Style" />

@code {
    [Parameter] public DateRange? DateRange { get; set; }
    [Parameter] public EventCallback<DateRange> DateRangeChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    [Parameter] public bool Editable { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public PickerVariant PickerVariant { get; set; } = PickerVariant.Dialog;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
}
