@using MudBlazor
@using Machsoft.DesignSystem.Theme

<MudThemeProvider Theme="@ResolvedTheme" IsDarkMode="@IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider MaxDisplayedSnackbars="@MaxSnackbars" PreventDuplicates="true" />

<CascadingValue Value="ResolvedTheme" Name="MxTheme">
    <CascadingValue Value="CurrentTokens" Name="MxTokens">
        @if (ApplyCssVariables)
        {
            <style>
                :root {
                    @CurrentTokens.ToCssVariables()
                }

                .mx-theme-scope.mx-theme-scope--light {
                    @LightTokens.ToCssVariables()
                }

                .mx-theme-scope.mx-theme-scope--dark {
                    @DarkTokens.ToCssVariables()
                }
            </style>
        }

        <div class="@ThemeScopeClass">
            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    [Parameter] public MudTheme? Theme { get; set; }

    [Parameter] public bool IsDarkMode { get; set; }

    [Parameter] public bool ApplyCssVariables { get; set; } = true;

    [Parameter] public int MaxSnackbars { get; set; } = 3;

    private MudTheme ResolvedTheme => Theme ?? AppTheme.Create();

    private DesignTokens CurrentTokens => DesignTokens.ForMode(IsDarkMode);

    private DesignTokens LightTokens => DesignTokens.Light;

    private DesignTokens DarkTokens => DesignTokens.Dark;

    private string ThemeScopeClass => IsDarkMode
        ? "mx-theme-scope mx-theme-scope--dark"
        : "mx-theme-scope mx-theme-scope--light";
}
