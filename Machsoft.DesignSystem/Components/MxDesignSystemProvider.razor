@using MudBlazor
@using Machsoft.DesignSystem.Theme

<MudThemeProvider Theme="@ResolvedTheme" IsDarkMode="@IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider MaxDisplayedSnackbars="@MaxSnackbars" PreventDuplicates="true" />

<CascadingValue Value="ResolvedTheme" Name="MxTheme">
    <CascadingValue Value="Tokens" Name="MxTokens">
        @if (ApplyCssVariables)
        {
            <style>
                :root {
                    @Tokens.ToCssVariables()
                }
            </style>
        }

        @ChildContent
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    [Parameter] public MudTheme? Theme { get; set; }

    [Parameter] public bool IsDarkMode { get; set; }

    [Parameter] public bool ApplyCssVariables { get; set; } = true;

    [Parameter] public int MaxSnackbars { get; set; } = 3;

    private MudTheme ResolvedTheme => Theme ?? AppTheme.Create();

    private DesignTokens Tokens { get; } = DesignTokens.Default;
}
