<NavigationLock ConfirmExternalNavigation="@When"
                OnBeforeInternalNavigation="@HandleBeforeInternalNavigationAsync" />

@code {
    [Parameter] public bool When { get; set; } = true;
    [Parameter] public EventCallback BeforeInternalNavigation { get; set; }

    private async Task HandleBeforeInternalNavigationAsync()
    {
        if (BeforeInternalNavigation.HasDelegate)
            await BeforeInternalNavigation.InvokeAsync();
    }
}
