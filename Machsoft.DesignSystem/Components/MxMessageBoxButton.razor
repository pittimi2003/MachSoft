@using MudBlazor
@inject IDialogService DialogService

<MxButton Variant="@Variant" Color="@Color" Disabled="@Disabled" OnClick="OpenAsync" Class="@Class" Style="@Style">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @ButtonText
    }
</MxButton>

@code {
    [Parameter] public string Title { get; set; } = "Mensaje";
    [Parameter] public string Message { get; set; } = "Contenido";
    [Parameter] public string CloseText { get; set; } = "Cerrar";
    [Parameter] public string ButtonText { get; set; } = "Abrir mensaje";
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private async Task OpenAsync(MouseEventArgs _)
    {
        await DialogService.ShowMessageBox(title: Title, markupMessage: (MarkupString)Message);
    }
}
