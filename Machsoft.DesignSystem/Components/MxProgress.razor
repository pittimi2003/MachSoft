@using MudBlazor

@if (Type == ProgressType.Circular)
{
    <MudProgressCircular Color="@Color"
                         Size="@Size"
                         Indeterminate="@Indeterminate"
                         Value="@Value"
                         Class="@Class"
                         Style="@Style" />
}
else
{
    <MudProgressLinear Color="@Color"
                       Rounded="@Rounded"
                       Buffer="@Buffer"
                       Indeterminate="@Indeterminate"
                       Value="@Value"
                       Class="@Class"
                       Style="@Style" />
}

@code {
    public enum ProgressType { Linear, Circular }

    [Parameter] public ProgressType Type { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public double Size { get; set; } = 40;
    [Parameter] public bool Indeterminate { get; set; } = true;
    [Parameter] public double Value { get; set; }
    [Parameter] public bool Rounded { get; set; }
    [Parameter] public double Buffer { get; set; } = 100;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
}
