@using MudBlazor

<MudTimePicker Time="@Time"
               TimeChanged="@TimeChanged"
               TimeExpression="@TimeExpression"
               Label="@Label"
               Variant="@Variant"
               Margin="@Margin"
               AmPm="@AmPm"
               Editable="@Editable"
               Disabled="@Disabled"
               PickerVariant="@PickerVariant"
               Class="@Class"
               Style="@Style" />

@code {
    [Parameter] public TimeSpan? Time { get; set; }
    [Parameter] public EventCallback<TimeSpan?> TimeChanged { get; set; }
    [Parameter] public Expression<Func<TimeSpan?>>? TimeExpression { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    [Parameter] public bool AmPm { get; set; }
    [Parameter] public bool Editable { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public PickerVariant PickerVariant { get; set; } = PickerVariant.Dialog;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
}
